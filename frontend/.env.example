# Frontend Environment Variables

# WalletConnect Project ID (get one at https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_ID=your_project_id_here

# Deployed contract addresses (fill after deployment)
NEXT_PUBLIC_MARKETPLACE_TESTNET=
NEXT_PUBLIC_ADAPTER_TESTNET=
NEXT_PUBLIC_ROUTER_TESTNET=
NEXT_PUBLIC_ADMIN_TESTNET=

NEXT_PUBLIC_MARKETPLACE_MAINNET=
NEXT_PUBLIC_ADAPTER_MAINNET=
NEXT_PUBLIC_ROUTER_MAINNET=
NEXT_PUBLIC_ADMIN_MAINNET=
